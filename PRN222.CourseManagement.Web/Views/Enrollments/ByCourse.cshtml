@model IEnumerable<CourseManagement.Models.Enrollment>

@{
    ViewData["Title"] = "Course Enrollments";
    var courseTitle = ViewBag.CourseTitle as string ?? "Course";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>Enrollments for @courseTitle</h2>
        </div>
        <div class="col text-end">
            <a asp-controller="Courses" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Courses
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Student Code</th>
                        <th>Student Name</th>
                        <th>Enroll Date</th>
                        <th>Grade</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Student?.StudentCode</td>
                                <td>@item.Student?.FullName</td>
                                <td>@item.EnrollDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (item.Grade.HasValue)
                                    {
                                        <span class="badge bg-info">@item.Grade.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not graded</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsGradeFinalized)
                                    {
                                        <span class="badge bg-success">Finalized</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">In Progress</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="AssignGrade" 
                                       asp-route-studentId="@item.StudentId" 
                                       asp-route-courseId="@item.CourseId" 
                                       class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil-square"></i> Grade
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">No enrollments found for this course.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
