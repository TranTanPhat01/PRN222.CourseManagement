@model PRN222.CourseManagement.Web.ViewModels.EnrollmentViewModel

@{
    ViewData["Title"] = "Assign Grade";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h3>Assign Grade</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-3">
                        <strong>Student:</strong> @Model.Student?.FullName (@Model.Student?.StudentCode)<br/>
                        <strong>Course:</strong> @Model.Course?.Title (@Model.Course?.CourseCode)
                    </div>

                    <form asp-action="AssignGrade" method="post">
                        <input type="hidden" asp-for="StudentId" />
                        <input type="hidden" asp-for="CourseId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="EnrollDate" class="form-label"></label>
                            <input asp-for="EnrollDate" type="date" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Grade" class="form-label"></label>
                            @if (Model.IsGradeFinalized)
                            {
                                <input asp-for="Grade" type="number" step="0.01" min="0" max="10" class="form-control" readonly />
                            }
                            else
                            {
                                <input asp-for="Grade" type="number" step="0.01" min="0" max="10" class="form-control" />
                            }
                            <span asp-validation-for="Grade" class="text-danger"></span>
                            @if (Model.IsGradeFinalized)
                            {
                                <small class="form-text text-danger">This grade has been finalized and cannot be changed.</small>
                            }
                            else
                            {
                                <small class="form-text text-muted">Grade must be between 0 and 10</small>
                            }
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsGradeFinalized" type="checkbox" class="form-check-input" disabled />
                            <label asp-for="IsGradeFinalized" class="form-check-label"></label>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            @if (!Model.IsGradeFinalized)
                            {
                                <button type="submit" class="btn btn-primary">Save Grade</button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
