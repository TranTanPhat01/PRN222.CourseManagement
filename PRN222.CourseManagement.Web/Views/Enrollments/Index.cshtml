@model IEnumerable<CourseManagement.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollments";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>Enrollments</h2>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Enroll Student
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Student Code</th>
                        <th>Student Name</th>
                        <th>Course Code</th>
                        <th>Course Title</th>
                        <th>Enroll Date</th>
                        <th>Grade</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Student?.StudentCode</td>
                                <td>@item.Student?.FullName</td>
                                <td>@item.Course?.CourseCode</td>
                                <td>@item.Course?.Title</td>
                                <td>@item.EnrollDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (item.Grade.HasValue)
                                    {
                                        <span class="badge bg-info">@item.Grade.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not graded</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsGradeFinalized)
                                    {
                                        <span class="badge bg-success">Finalized</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">In Progress</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="AssignGrade" 
                                       asp-route-studentId="@item.StudentId" 
                                       asp-route-courseId="@item.CourseId" 
                                       class="btn btn-sm btn-primary" 
                                       title="Assign/Edit Grade">
                                        <i class="bi bi-pencil-square"></i> Grade
                                    </a>

                                    @if (!item.IsGradeFinalized && item.Grade.HasValue)
                                    {
                                        <form asp-action="FinalizeGrade" method="post" class="d-inline">
                                            <input type="hidden" name="studentId" value="@item.StudentId" />
                                            <input type="hidden" name="courseId" value="@item.CourseId" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Finalize Grade">
                                                <i class="bi bi-check-circle"></i> Finalize
                                            </button>
                                        </form>
                                    }

                                    @if (!item.IsGradeFinalized)
                                    {
                                        <a asp-action="Delete" 
                                           asp-route-studentId="@item.StudentId" 
                                           asp-route-courseId="@item.CourseId" 
                                           class="btn btn-sm btn-danger" 
                                           title="Unenroll">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">No enrollments found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
