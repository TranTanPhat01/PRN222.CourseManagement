@model IEnumerable<CourseManagement.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>Courses</h2>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Course
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Course Code</th>
                        <th>Title</th>
                        <th>Credits</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            string rowClass = "";
                            if (item.Status == CourseManagement.Models.CourseStatus.Inactive)
                            {
                                rowClass = "table-warning";
                            }
                            else if (item.Status == CourseManagement.Models.CourseStatus.Archived)
                            {
                                rowClass = "table-secondary";
                            }

                            <tr class="@rowClass">
                                <td>@item.CourseCode</td>
                                <td>@item.Title</td>
                                <td>@item.Credits</td>
                                <td>@item.Department?.Name</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case CourseManagement.Models.CourseStatus.Active:
                                            <span class="badge bg-success">Active</span>
                                            break;
                                        case CourseManagement.Models.CourseStatus.Inactive:
                                            <span class="badge bg-warning text-dark">Inactive</span>
                                            break;
                                        case CourseManagement.Models.CourseStatus.Archived:
                                            <span class="badge bg-secondary">Archived</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-sm btn-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                    <a asp-controller="Enrollments" asp-action="ByCourse" asp-route-id="@item.CourseId" 
                                       class="btn btn-sm btn-secondary" title="View Enrollments">
                                        <i class="bi bi-people"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">No courses found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
